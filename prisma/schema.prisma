generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
}

model Member {
  id        String   @id @default(cuid())
  name      String   @unique
  setor     Decimal  @db.Decimal(12, 2)
  sisa      Decimal  @db.Decimal(12, 2)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pocket {
  id        String   @id @default(cuid())
  name      String   @unique
  total     Decimal  @db.Decimal(12, 2)
  spent     Decimal  @db.Decimal(12, 2)
  icon      String   @default("Wallet")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id        String   @id @default(cuid())
  type      String
  desc      String
  amount    Decimal  @db.Decimal(12, 2)
  time      String
  createdAt DateTime @default(now())
  pocket    String
  dicatat   String
  image     String?

  @@index([type])
  @@index([pocket])
  @@index([dicatat])
  @@index([createdAt])
}
